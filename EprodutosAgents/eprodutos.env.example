# Copie este arquivo para EprodutosAgents/eprodutos.env e ajuste os valores.
#
# Se o MongoDB estiver instalado diretamente na VM Linux host:
EPRODUTOS_MONGO_CONNECTION_STRING=mongodb://host.docker.internal:27017/eprodutos
#
# Se o MongoDB estiver em outro container na mesma rede Docker, use algo como:
# EPRODUTOS_MONGO_CONNECTION_STRING=mongodb://mongo:27017/eprodutos
#
# Se estiver usando MongoDB Atlas ou outro servidor externo:
# EPRODUTOS_MONGO_CONNECTION_STRING=mongodb+srv://usuario:senha@cluster.example.mongodb.net/eprodutos

EPRODUTOS_MONGO_DATABASE=eprodutos
EPRODUTOS_PRODUCTS_COLLECTION=products
EPRODUTOS_STOCKS_COLLECTION=stocks

# O docker-compose.yml define o perfil por servico:
# - eprodutos-customer => EPRODUTOS_ACCESS_PROFILE=customer
# - eprodutos-employee => EPRODUTOS_ACCESS_PROFILE=employee
#
# Para docker run direto, descomente uma das linhas abaixo:
# EPRODUTOS_ACCESS_PROFILE=customer
# EPRODUTOS_ACCESS_PROFILE=employee
