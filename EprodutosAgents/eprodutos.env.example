# Copie este arquivo para EprodutosAgents/eprodutos.env e ajuste os valores.

# Fora de container, use exatamente o Mongo local pedido:
EPRODUTOS_MONGO_CONNECTION_STRING=mongodb://localhost:27017/

# Dentro de container Docker, se o MongoDB estiver no host da maquina, use:
# EPRODUTOS_MONGO_CONNECTION_STRING=mongodb://host.docker.internal:27017/
#
# Se o MongoDB estiver em outro container na mesma rede Docker, use algo como:
# EPRODUTOS_MONGO_CONNECTION_STRING=mongodb://mongo:27017/

EPRODUTOS_MONGO_DATABASE=eprodutos
EPRODUTOS_PRODUCTS_COLLECTION=products
EPRODUTOS_STOCKS_COLLECTION=stocks
EPRODUTOS_USERS_COLLECTION=users
EPRODUTOS_MCP_API_KEYS_COLLECTION=mcp_api_keys
EPRODUTOS_MCP_AUDIT_LOGS_COLLECTION=mcp_audit_logs

# Chave administrativa usada apenas para criar/listar/revogar API keys MCP.
# Gere um valor forte e envie em X-MCP-ADMIN-KEY nos endpoints /api/mcp/api-keys.
# Exemplo para gerar: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
EPRODUTOS_MCP_ADMIN_KEY=

# Por padrao o docker-compose publica apenas em localhost.
EPRODUTOS_MCP_BIND_ADDRESS=127.0.0.1

# Use true somente atras de um proxy confiavel configurado para X-Forwarded-*.
EPRODUTOS_TRUST_FORWARDED_HEADERS=false
EPRODUTOS_MCP_REQUIRE_HTTPS=false

ASPNETCORE_URLS=http://0.0.0.0:8080
